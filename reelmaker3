<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reel Maker</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.5/babel.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #0d0d18; color: #fff; font-family: 'DM Sans', 'Segoe UI', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    input, textarea, button, select { font-family: inherit; }
    input[type="range"] { accent-color: #ff3c7e; cursor: pointer; }
    textarea { resize: vertical; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0d0d18; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 999px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useRef } = React;

    const NICHES = ["Lifestyle","Fitness","Food","Travel","Fashion","Beauty","Business","Tech"];
    const TEXT_STYLES = [
      { id:"bold",   label:"BOLD",   sub:"BOLD",     fontWeight:900, color:"#fff" },
      { id:"stroke", label:"STROKE", sub:"OUTLINED", fontWeight:700, color:"#ff3c7e" },
      { id:"pill",   label:"PILL",   sub:"PILL",     fontWeight:700, color:"#fff", bg:"#ff3c7e", pill:true },
      { id:"shadow", label:"SHADOW", sub:"SHADOW",   fontWeight:900, color:"#ff3c7e", shadow:true },
      { id:"grad",   label:"GRAD",   sub:"GRADIENT", fontWeight:900, grad:true },
      { id:"clean",  label:"clean",  sub:"CLEAN",    fontWeight:400, color:"#fff" },
    ];
    const ACCENT_COLORS = ["Pink","Purple","Cyan","Gold","Green","White"];
    const ACCENT_MAP = { Pink:"#ff3c7e", Purple:"#a855f7", Cyan:"#06b6d4", Gold:"#f59e0b", Green:"#22c55e", White:"#ffffff" };
    const OVERLAYS = [
      { id:"vignette", label:"Vignette",           icon:"🌑" },
      { id:"bars",     label:"Cinematic Black Bars",icon:"🎬" },
      { id:"grain",    label:"Film Grain",          icon:"📽️" },
      { id:"blur",     label:"Edge Blur",           icon:"🔆" },
    ];
    const EMOJIS = ["⬛","🔥","✨","💯","🙌","💪","🎉","☀️","👏","↩️","😎","🤩","🌸","🦋","🎵","🧚","🏆","👑","💎","🌈","▶️","🧿","🌊","🎯","🌴","🎮","💡"];

    /* ── tiny helpers ── */
    const card = { background:"rgba(255,255,255,0.03)", border:"1px solid rgba(255,255,255,0.07)", borderRadius:14, padding:"20px 22px", marginBottom:14 };
    const pill_btn = (active, col) => ({
      padding:"5px 14px", borderRadius:999, fontSize:12, fontWeight:500, cursor:"pointer",
      border:`1px solid ${active ? col : "rgba(255,255,255,0.12)"}`,
      background: active ? col+"22" : "transparent",
      color: active ? col : "rgba(255,255,255,0.6)", transition:"all .15s",
    });
    const icon_btn = { padding:"7px 18px", borderRadius:7, fontSize:12, fontWeight:500, cursor:"pointer", border:"1px solid rgba(255,255,255,0.15)", background:"rgba(255,255,255,0.04)", color:"rgba(255,255,255,0.7)", transition:"all .15s" };

    function SectionHeader({ num, title }) {
      return (
        <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:16 }}>
          <div style={{ width:24, height:24, borderRadius:"50%", background:"linear-gradient(135deg,#ff3c7e,#a855f7)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:800, color:"#fff", flexShrink:0 }}>{num}</div>
          <span style={{ fontSize:11, fontWeight:700, letterSpacing:"0.15em", color:"rgba(255,255,255,0.55)", textTransform:"uppercase" }}>{title}</span>
        </div>
      );
    }

    function Label({ children, mt }) {
      return <div style={{ fontSize:10, letterSpacing:"0.12em", color:"rgba(255,255,255,0.4)", textTransform:"uppercase", marginBottom:8, marginTop:mt||0 }}>{children}</div>;
    }

    function Toggle({ on, onToggle }) {
      return (
        <div onClick={onToggle} style={{ width:42, height:24, borderRadius:999, cursor:"pointer", background: on ? "linear-gradient(90deg,#ff3c7e,#a855f7)" : "rgba(255,255,255,0.1)", position:"relative", transition:"background .2s", flexShrink:0 }}>
          <div style={{ position:"absolute", top:3, left: on ? 21 : 3, width:18, height:18, borderRadius:"50%", background:"#fff", transition:"left .2s", boxShadow:"0 1px 4px rgba(0,0,0,0.4)" }} />
        </div>
      );
    }

    function DashedUpload({ icon, label, sub, onClick }) {
      const [hover, setHover] = useState(false);
      return (
        <div onClick={onClick} onMouseEnter={() => setHover(true)} onMouseLeave={() => setHover(false)}
          style={{ flex:1, border:`1.5px dashed ${hover ? "#ff3c7e" : "rgba(255,255,255,0.15)"}`, borderRadius:10, padding:"24px 12px", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", gap:6, cursor:"pointer", background: hover ? "rgba(255,60,126,0.05)" : "transparent", transition:"all .2s" }}>
          <span style={{ fontSize:26 }}>{icon}</span>
          <span style={{ fontSize:13, fontWeight:600, color:"rgba(255,255,255,0.8)" }}>{label}</span>
          <span style={{ fontSize:10, color:"rgba(255,255,255,0.35)", letterSpacing:"0.08em" }}>{sub}</span>
        </div>
      );
    }

    function App() {
      const [clips, setClips] = useState([]);
      const [brief, setBrief] = useState("");
      const [niche, setNiche] = useState("Lifestyle");
      const [caption, setCaption] = useState("");
      const [handle, setHandle] = useState("");
      const [textStyle, setTextStyle] = useState("bold");
      const [fontSize, setFontSize] = useState(46);
      const [accentColor, setAccentColor] = useState("Pink");
      const [activeOverlays, setActiveOverlays] = useState({});
      const [emojiInput, setEmojiInput] = useState("");
      const [emojiSize, setEmojiSize] = useState(64);
      const [layers, setLayers] = useState([]);
      const [generatedCaption, setGeneratedCaption] = useState("");
      const [generating, setGenerating] = useState(false);
      const [apiKey, setApiKey] = useState("");
      const [showApiKey, setShowApiKey] = useState(false);
      // export
      const [exportFormat, setExportFormat] = useState("MP4");
      const [exportQuality, setExportQuality] = useState("1080p");
      const [exportRatio, setExportRatio] = useState("9:16");
      const [exportFps, setExportFps] = useState("30fps");
      const [exporting, setExporting] = useState(false);
      const [exportProgress, setExportProgress] = useState(0);
      const [exportDone, setExportDone] = useState(false);

      const videoInputRef = useRef(null);
      const imageInputRef = useRef(null);
      const overlayInputRef = useRef(null);

      const addClips = (files, type) => {
        const newClips = files.map(f => ({ id: Date.now()+Math.random(), name:f.name, url:URL.createObjectURL(f), duration: type==="VID" ? "8.0s" : "5.0s", type }));
        setClips(p => [...p, ...newClips]);
        setLayers(p => [...p, ...newClips.map(c => ({ id:c.id, label:c.name, type: type==="VID" ? "video" : "image", visible:true }))]);
      };

      const removeClip = id => { setClips(p => p.filter(c => c.id!==id)); setLayers(p => p.filter(l => l.id!==id)); };
      const toggleOverlay = id => setActiveOverlays(p => ({ ...p, [id]: !p[id] }));
      const addEmoji = em => { const id=Date.now(); setLayers(p => [...p, { id, label:em, type:"emoji", visible:true }]); };
      const addShape = sh => { const id=Date.now(); setLayers(p => [...p, { id, label:sh, type:"shape", visible:true }]); };

      const generateCaptions = async () => {
        if (!apiKey) { setShowApiKey(true); return; }
        setGenerating(true);
        setGeneratedCaption("");
        try {
          const res = await fetch("https://api.anthropic.com/v1/messages", {
            method:"POST",
            headers:{ "Content-Type":"application/json", "x-api-key": apiKey, "anthropic-version":"2023-06-01", "anthropic-dangerous-direct-browser-access":"true" },
            body: JSON.stringify({
              model:"claude-sonnet-4-20250514",
              max_tokens:800,
              messages:[{ role:"user", content:`Generate 3 short, punchy social media reel captions for a ${niche} reel about "${brief||"general content"}". Each 1-2 lines, engaging, with relevant emojis. Numbered list.` }]
            })
          });
          const data = await res.json();
          const text = data.content?.find(b => b.type==="text")?.text || "No captions returned.";
          setGeneratedCaption(text);
          setLayers(p => [...p, { id:Date.now(), label:"AI Captions", type:"text", visible:true }]);
        } catch(err) {
          setGeneratedCaption("Error: " + err.message);
        }
        setGenerating(false);
      };

      const startExport = () => {
        setExporting(true); setExportDone(false); setExportProgress(0);
        let p = 0;
        const iv = setInterval(() => {
          p += Math.random()*12+4;
          if (p >= 100) { clearInterval(iv); setExportProgress(100); setTimeout(() => { setExporting(false); setExportDone(true); }, 400); }
          else setExportProgress(Math.round(p));
        }, 220);
      };

      const previewBg = clips.find(c => c.type==="IMG")?.url || null;
      const activeTextStyle = TEXT_STYLES.find(t => t.id===textStyle);

      /* ── render ── */
      return (
        <div style={{ minHeight:"100vh", background:"#0d0d18", color:"#fff", fontFamily:"'DM Sans','Segoe UI',sans-serif" }}>

          {/* Header */}
          <div style={{ textAlign:"center", padding:"36px 20px 24px" }}>
            <h1 style={{ fontSize:"clamp(36px,7vw,64px)", fontWeight:900, margin:0, letterSpacing:"-0.02em", lineHeight:1 }}>
              <span style={{ color:"#ff3c7e" }}>REEL </span><span style={{ color:"#fff" }}>MAKER</span>
            </h1>
            <p style={{ fontSize:11, letterSpacing:"0.2em", color:"rgba(255,255,255,0.35)", marginTop:10, textTransform:"uppercase" }}>SEQUENCE · STYLE · OVERLAY · DOWNLOAD</p>
          </div>

          {/* API Key banner */}
          {showApiKey && (
            <div style={{ maxWidth:1200, margin:"0 auto 16px", padding:"0 20px" }}>
              <div style={{ background:"rgba(255,60,126,0.08)", border:"1px solid rgba(255,60,126,0.25)", borderRadius:10, padding:"14px 16px", display:"flex", alignItems:"center", gap:12, flexWrap:"wrap" }}>
                <span style={{ fontSize:13, color:"rgba(255,255,255,0.7)", flex:1 }}>🔑 Enter your Anthropic API key to generate captions:</span>
                <input value={apiKey} onChange={e => setApiKey(e.target.value)} placeholder="sk-ant-..." type="password"
                  style={{ flex:"0 0 280px", background:"rgba(0,0,0,0.3)", border:"1px solid rgba(255,60,126,0.3)", borderRadius:7, color:"#fff", fontSize:13, padding:"8px 12px", outline:"none" }} />
                <button onClick={() => setShowApiKey(false)} style={{ padding:"8px 16px", borderRadius:7, background:"#ff3c7e", border:"none", color:"#fff", fontSize:12, fontWeight:700, cursor:"pointer" }}>Save</button>
              </div>
            </div>
          )}

          {/* Main layout */}
          <div style={{ display:"flex", gap:16, padding:"0 20px 60px", maxWidth:1200, margin:"0 auto", alignItems:"flex-start" }}>

            {/* ══════════ LEFT PANEL ══════════ */}
            <div style={{ flex:"0 0 560px", minWidth:0 }}>

              {/* 1. Media Sequence */}
              <div style={card}>
                <SectionHeader num="1" title="Media Sequence" />
                <div style={{ display:"flex", gap:10, marginBottom:16 }}>
                  <DashedUpload icon="🎬" label="Add Video(s)" sub="MP4 · MOV · WebM" onClick={() => videoInputRef.current?.click()} />
                  <DashedUpload icon="🖼️" label="Add Image(s)" sub="JPG · PNG · WebP" onClick={() => imageInputRef.current?.click()} />
                  <input ref={videoInputRef} type="file" accept="video/*" multiple style={{ display:"none" }} onChange={e => addClips(Array.from(e.target.files),"VID")} />
                  <input ref={imageInputRef} type="file" accept="image/*" multiple style={{ display:"none" }} onChange={e => addClips(Array.from(e.target.files),"IMG")} />
                </div>
                {clips.length > 0 && <>
                  <div style={{ display:"flex", justifyContent:"space-between", marginBottom:8 }}>
                    <span style={{ fontSize:10, letterSpacing:"0.12em", color:"rgba(255,255,255,0.35)", textTransform:"uppercase" }}>Playback Order</span>
                    <span style={{ fontSize:10, color:"rgba(255,255,255,0.25)" }}>click × to remove</span>
                  </div>
                  <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
                    {clips.map(clip => (
                      <div key={clip.id} style={{ position:"relative", width:72 }}>
                        <div style={{ width:72, height:72, borderRadius:8, overflow:"hidden", background:"#1a1a2e", border:"1px solid rgba(255,255,255,0.1)" }}>
                          {clip.type==="IMG"
                            ? <img src={clip.url} alt="" style={{ width:"100%", height:"100%", objectFit:"cover" }} />
                            : <div style={{ width:"100%", height:"100%", display:"flex", alignItems:"center", justifyContent:"center", fontSize:24 }}>🎬</div>}
                        </div>
                        <div style={{ position:"absolute", top:3, left:3, background:"rgba(0,0,0,0.7)", borderRadius:3, padding:"1px 4px", fontSize:9, fontWeight:700, color: clip.type==="VID" ? "#60a5fa" : "#a78bfa" }}>{clip.type}</div>
                        <button onClick={() => removeClip(clip.id)} style={{ position:"absolute", top:2, right:2, width:16, height:16, borderRadius:"50%", background:"#ef4444", border:"none", color:"#fff", fontSize:9, cursor:"pointer" }}>×</button>
                        <div style={{ textAlign:"center", fontSize:10, color:"rgba(255,255,255,0.5)", marginTop:3 }}>{clip.duration}</div>
                      </div>
                    ))}
                  </div>
                  <div style={{ marginTop:10, fontSize:11, color:"rgba(255,255,255,0.35)" }}>{clips.length} clip{clips.length!==1?"s":""} · {clips.length*8}s total</div>
                </>}
              </div>

              {/* Picture-in-Picture */}
              <div style={card}>
                <div style={{ display:"flex", alignItems:"center", gap:10, marginBottom:14 }}>
                  <div style={{ width:24, height:24, borderRadius:"50%", background:"linear-gradient(135deg,#ff3c7e,#a855f7)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:800, color:"#fff" }}>↗</div>
                  <span style={{ fontSize:11, fontWeight:700, letterSpacing:"0.15em", color:"rgba(255,255,255,0.55)", textTransform:"uppercase" }}>Picture-in-Picture</span>
                </div>
                <DashedUpload icon="🖼️+" label="Add overlay images" sub="Drag on preview · corner handle to resize" onClick={() => overlayInputRef.current?.click()} />
                <input ref={overlayInputRef} type="file" accept="image/*" multiple style={{ display:"none" }} onChange={e => { const files=Array.from(e.target.files); setLayers(p => [...p, ...files.map(f => ({ id:Date.now()+Math.random(), label:f.name, type:"overlay", visible:true }))]); }} />
              </div>

              {/* 2. Caption Brief */}
              <div style={card}>
                <SectionHeader num="2" title="Caption Brief" />
                <Label>What's your reel about?</Label>
                <textarea value={brief} onChange={e => setBrief(e.target.value)} placeholder="e.g. food, fitness tips, travel vlog..."
                  style={{ width:"100%", minHeight:60, background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:8, color:"#fff", fontSize:14, padding:"10px 12px", outline:"none" }} />
                <Label mt={14}>Niche</Label>
                <div style={{ display:"flex", flexWrap:"wrap", gap:6 }}>
                  {NICHES.map(n => <button key={n} onClick={() => setNiche(n)} style={pill_btn(niche===n,"#ff3c7e")}>{n}</button>)}
                </div>
                <Label mt={14}>Caption Text</Label>
                <input value={caption} onChange={e => setCaption(e.target.value)} placeholder="Your caption here..."
                  style={{ width:"100%", background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:8, color:"#fff", fontSize:14, padding:"10px 12px", outline:"none" }} />
                <Label mt={12}>Handle</Label>
                <input value={handle} onChange={e => setHandle(e.target.value)} placeholder="@yourhandle"
                  style={{ width:"100%", background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:8, color:"#fff", fontSize:14, padding:"10px 12px", outline:"none" }} />
              </div>

              {/* 3. Text Style */}
              <div style={card}>
                <SectionHeader num="3" title="Text Style" />
                <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:8, marginBottom:16 }}>
                  {TEXT_STYLES.map(ts => (
                    <button key={ts.id} onClick={() => setTextStyle(ts.id)} style={{ padding:"12px 8px", borderRadius:8, cursor:"pointer", border:`1.5px solid ${textStyle===ts.id ? "#ff3c7e" : "rgba(255,255,255,0.1)"}`, background: textStyle===ts.id ? "rgba(255,60,126,0.1)" : "rgba(255,255,255,0.03)", display:"flex", flexDirection:"column", alignItems:"center", gap:4, transition:"all .15s" }}>
                      <span style={{ fontSize:16, fontWeight:ts.fontWeight, color: ts.grad ? "transparent" : ts.pill ? "#fff" : ts.color, background: ts.grad ? "linear-gradient(90deg,#ff3c7e,#a855f7)" : ts.pill ? "#ff3c7e" : "transparent", WebkitBackgroundClip: ts.grad ? "text" : "unset", borderRadius: ts.pill ? "999px" : 0, padding: ts.pill ? "2px 10px" : 0, textShadow: ts.shadow ? "3px 3px 0 #000" : "none" }}>{ts.label}</span>
                      <span style={{ fontSize:9, color:"rgba(255,255,255,0.4)", letterSpacing:"0.1em" }}>{ts.sub}</span>
                    </button>
                  ))}
                </div>
                <Label>Font Size</Label>
                <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                  <span style={{ fontSize:10, color:"rgba(255,255,255,0.35)" }}>S</span>
                  <input type="range" min={12} max={96} value={fontSize} onChange={e => setFontSize(+e.target.value)} style={{ flex:1 }} />
                  <span style={{ fontSize:10, color:"rgba(255,255,255,0.35)" }}>XL</span>
                  <span style={{ fontSize:11, color:"#ff3c7e", fontWeight:700, minWidth:32 }}>{fontSize}px</span>
                </div>
                <Label mt={14}>Accent Color</Label>
                <div style={{ display:"flex", gap:6, flexWrap:"wrap" }}>
                  {ACCENT_COLORS.map(c => <button key={c} onClick={() => setAccentColor(c)} style={pill_btn(accentColor===c, ACCENT_MAP[c])}>{c}</button>)}
                </div>
              </div>

              {/* 4. Overlays */}
              <div style={card}>
                <SectionHeader num="4" title="Overlays" />
                {OVERLAYS.map(ov => (
                  <div key={ov.id} style={{ display:"flex", alignItems:"center", justifyContent:"space-between", padding:"10px 0", borderBottom:"1px solid rgba(255,255,255,0.06)" }}>
                    <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                      <span style={{ fontSize:18 }}>{ov.icon}</span>
                      <span style={{ fontSize:13, color:"rgba(255,255,255,0.8)" }}>{ov.label}</span>
                    </div>
                    <Toggle on={!!activeOverlays[ov.id]} onToggle={() => toggleOverlay(ov.id)} />
                  </div>
                ))}
              </div>

              {/* 5. Shapes & Covers */}
              <div style={card}>
                <SectionHeader num="5" title="Shapes & Covers" />
                <div style={{ display:"flex", gap:8 }}>
                  {["Rectangle","Circle"].map(s => (
                    <button key={s} onClick={() => addShape(s)} style={icon_btn}>
                      {s==="Rectangle" ? "▭" : "○"} {s}
                    </button>
                  ))}
                </div>
              </div>

              {/* 6. Emojis */}
              <div style={card}>
                <SectionHeader num="6" title="Emojis" />
                <div style={{ display:"flex", gap:8, marginBottom:12 }}>
                  <input value={emojiInput} onChange={e => setEmojiInput(e.target.value)} placeholder="Type or paste emoji..."
                    style={{ flex:1, background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:8, color:"#fff", fontSize:14, padding:"9px 12px", outline:"none" }} />
                  <button onClick={() => { if(emojiInput){ addEmoji(emojiInput); setEmojiInput(""); }}} style={{ padding:"9px 16px", background:"#ff3c7e", border:"none", borderRadius:8, color:"#fff", fontSize:13, fontWeight:700, cursor:"pointer" }}>+ Add</button>
                </div>
                <div style={{ display:"flex", flexWrap:"wrap", gap:6, marginBottom:12 }}>
                  {EMOJIS.map((em,i) => (
                    <button key={i} onClick={() => addEmoji(em)} style={{ fontSize:20, background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.08)", borderRadius:6, width:36, height:36, cursor:"pointer", transition:"all .12s" }}
                      onMouseEnter={e => { e.currentTarget.style.background="rgba(255,60,126,0.15)"; e.currentTarget.style.borderColor="#ff3c7e"; }}
                      onMouseLeave={e => { e.currentTarget.style.background="rgba(255,255,255,0.04)"; e.currentTarget.style.borderColor="rgba(255,255,255,0.08)"; }}
                    >{em}</button>
                  ))}
                </div>
                <div style={{ display:"flex", alignItems:"center", gap:10 }}>
                  <span style={{ fontSize:10, color:"rgba(255,255,255,0.4)", textTransform:"uppercase", letterSpacing:"0.1em" }}>Size</span>
                  <input type="range" min={16} max={128} value={emojiSize} onChange={e => setEmojiSize(+e.target.value)} style={{ flex:1 }} />
                  <span style={{ fontSize:11, color:"#ff3c7e", fontWeight:700, minWidth:34 }}>{emojiSize}px</span>
                </div>
                <div style={{ fontSize:10, color:"rgba(255,255,255,0.3)", marginTop:6 }}>Click to place · drag on preview to move</div>
              </div>

              {/* 7. Voiceover / Audio */}
              <div style={card}>
                <SectionHeader num="7" title="Voiceover / Audio" />
                <div style={{ display:"flex", gap:10 }}>
                  {[{label:"🎙️ Record", hov:"#ff3c7e"},{label:"📁 Upload Audio", hov:"#f59e0b"}].map(b => (
                    <button key={b.label} style={{ flex:1, padding:11, background:"rgba(255,255,255,0.04)", border:"1px solid rgba(255,255,255,0.1)", borderRadius:8, color:"rgba(255,255,255,0.75)", fontSize:13, fontWeight:500, cursor:"pointer", transition:"all .15s" }}
                      onMouseEnter={e => { e.currentTarget.style.borderColor=b.hov; e.currentTarget.style.color="#fff"; }}
                      onMouseLeave={e => { e.currentTarget.style.borderColor="rgba(255,255,255,0.1)"; e.currentTarget.style.color="rgba(255,255,255,0.75)"; }}
                    >{b.label}</button>
                  ))}
                </div>
              </div>

              {/* Generate Captions */}
              <button onClick={generateCaptions} disabled={generating} style={{ width:"100%", padding:16, borderRadius:12, border:"none", background: generating ? "rgba(255,60,126,0.4)" : "linear-gradient(90deg,#ff3c7e,#a855f7)", color:"#fff", fontSize:15, fontWeight:800, letterSpacing:"0.12em", cursor: generating ? "not-allowed" : "pointer", textTransform:"uppercase", boxShadow: generating ? "none" : "0 4px 24px rgba(255,60,126,0.35)", marginBottom:14 }}>
                {generating ? "⏳ GENERATING…" : "✦ GENERATE CAPTIONS"}
              </button>

              {generatedCaption && (
                <div style={{ background:"rgba(168,85,247,0.1)", border:"1px solid rgba(168,85,247,0.2)", borderRadius:10, padding:"14px 16px", marginBottom:14 }}>
                  <div style={{ fontSize:10, color:"rgba(168,85,247,0.8)", letterSpacing:"0.12em", textTransform:"uppercase", marginBottom:8 }}>✦ AI Generated Captions</div>
                  <pre style={{ margin:0, fontSize:13, color:"rgba(255,255,255,0.85)", whiteSpace:"pre-wrap", fontFamily:"inherit", lineHeight:1.6 }}>{generatedCaption}</pre>
                </div>
              )}

              {/* 8. Export & Download */}
              <div style={card}>
                <SectionHeader num="8" title="Export & Download" />

                <Label>Format</Label>
                <div style={{ display:"flex", gap:8, marginBottom:16 }}>
                  {["MP4","MOV","GIF"].map(f => (
                    <button key={f} onClick={() => setExportFormat(f)} style={{ flex:1, padding:"9px 0", borderRadius:8, fontSize:13, fontWeight:700, cursor:"pointer", border:`1.5px solid ${exportFormat===f ? "#ff3c7e" : "rgba(255,255,255,0.1)"}`, background: exportFormat===f ? "rgba(255,60,126,0.12)" : "rgba(255,255,255,0.03)", color: exportFormat===f ? "#ff3c7e" : "rgba(255,255,255,0.55)", transition:"all .15s" }}>{f}</button>
                  ))}
                </div>

                <Label>Quality</Label>
                <div style={{ display:"flex", gap:8, marginBottom:16 }}>
                  {["720p","1080p","4K"].map(q => (
                    <button key={q} onClick={() => setExportQuality(q)} style={{ flex:1, padding:"9px 0", borderRadius:8, fontSize:13, fontWeight:700, cursor:"pointer", border:`1.5px solid ${exportQuality===q ? "#a855f7" : "rgba(255,255,255,0.1)"}`, background: exportQuality===q ? "rgba(168,85,247,0.12)" : "rgba(255,255,255,0.03)", color: exportQuality===q ? "#a855f7" : "rgba(255,255,255,0.55)", transition:"all .15s" }}>
                      {q}{q==="4K" && <span style={{ fontSize:9, marginLeft:4, background:"rgba(168,85,247,0.3)", padding:"1px 5px", borderRadius:4 }}> PRO</span>}
                    </button>
                  ))}
                </div>

                <div style={{ display:"flex", gap:16, marginBottom:16 }}>
                  <div style={{ flex:1 }}>
                    <Label>Aspect Ratio</Label>
                    <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
                      {[["9:16","Reels/TikTok"],["1:1","Square"],["16:9","YouTube"]].map(([r,hint]) => (
                        <button key={r} onClick={() => setExportRatio(r)} style={{ padding:"7px 10px", borderRadius:7, fontSize:12, fontWeight:600, cursor:"pointer", border:`1.5px solid ${exportRatio===r ? "#06b6d4" : "rgba(255,255,255,0.08)"}`, background: exportRatio===r ? "rgba(6,182,212,0.1)" : "rgba(255,255,255,0.02)", color: exportRatio===r ? "#06b6d4" : "rgba(255,255,255,0.5)", display:"flex", alignItems:"center", gap:8, transition:"all .15s" }}>
                          <div style={{ width: r==="9:16"?10:r==="1:1"?14:22, height: r==="9:16"?16:r==="1:1"?14:10, border:`2px solid ${exportRatio===r ? "#06b6d4" : "rgba(255,255,255,0.3)"}`, borderRadius:2, flexShrink:0 }} />
                          {r} <span style={{ fontSize:9, color:"rgba(255,255,255,0.3)" }}>· {hint}</span>
                        </button>
                      ))}
                    </div>
                  </div>
                  <div style={{ flex:1 }}>
                    <Label>Frame Rate</Label>
                    <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
                      {[["24fps","Cinematic"],["30fps",""],["60fps","Smooth"]].map(([fps,hint]) => (
                        <button key={fps} onClick={() => setExportFps(fps)} style={{ padding:"7px 10px", borderRadius:7, fontSize:12, fontWeight:600, cursor:"pointer", border:`1.5px solid ${exportFps===fps ? "#f59e0b" : "rgba(255,255,255,0.08)"}`, background: exportFps===fps ? "rgba(245,158,11,0.1)" : "rgba(255,255,255,0.02)", color: exportFps===fps ? "#f59e0b" : "rgba(255,255,255,0.5)", transition:"all .15s" }}>
                          {fps}{hint && <span style={{ fontSize:9, color:"rgba(255,255,255,0.3)", marginLeft:4 }}>· {hint}</span>}
                        </button>
                      ))}
                    </div>
                  </div>
                </div>

                {/* Summary */}
                <div style={{ background:"rgba(255,255,255,0.03)", border:"1px solid rgba(255,255,255,0.07)", borderRadius:8, padding:"10px 14px", marginBottom:16, display:"flex", justifyContent:"space-between" }}>
                  <span style={{ fontSize:11, color:"rgba(255,255,255,0.4)" }}>{exportRatio} · {exportQuality} · {exportFps} · {exportFormat}</span>
                  <span style={{ fontSize:11, color:"rgba(255,255,255,0.25)" }}>~{exportQuality==="4K"?"800":exportQuality==="1080p"?"250":"80"}MB est.</span>
                </div>

                {/* Progress */}
                {exporting && (
                  <div style={{ marginBottom:14 }}>
                    <div style={{ display:"flex", justifyContent:"space-between", marginBottom:6 }}>
                      <span style={{ fontSize:11, color:"rgba(255,255,255,0.5)" }}>Rendering reel…</span>
                      <span style={{ fontSize:11, color:"#ff3c7e", fontWeight:700 }}>{exportProgress}%</span>
                    </div>
                    <div style={{ height:6, background:"rgba(255,255,255,0.08)", borderRadius:999, overflow:"hidden" }}>
                      <div style={{ height:"100%", width:`${exportProgress}%`, background:"linear-gradient(90deg,#ff3c7e,#a855f7)", borderRadius:999, transition:"width .3s ease" }} />
                    </div>
                  </div>
                )}

                {exportDone && (
                  <div style={{ marginBottom:14, background:"rgba(34,197,94,0.1)", border:"1px solid rgba(34,197,94,0.25)", borderRadius:8, padding:"10px 14px", display:"flex", alignItems:"center", gap:8 }}>
                    <span style={{ fontSize:18 }}>✅</span>
                    <span style={{ fontSize:13, color:"#22c55e", fontWeight:600 }}>Reel exported successfully!</span>
                  </div>
                )}

                <button onClick={startExport} disabled={exporting} style={{ width:"100%", padding:15, borderRadius:12, border:"none", background: exporting ? "rgba(255,255,255,0.06)" : "linear-gradient(90deg,#ff3c7e,#a855f7)", color: exporting ? "rgba(255,255,255,0.4)" : "#fff", fontSize:15, fontWeight:800, letterSpacing:"0.12em", cursor: exporting ? "not-allowed" : "pointer", textTransform:"uppercase", boxShadow: exporting ? "none" : "0 4px 24px rgba(255,60,126,0.35)", transition:"all .2s" }}>
                  {exporting ? `⏳ RENDERING… ${exportProgress}%` : exportDone ? "⬇ DOWNLOAD REEL" : "⬇ EXPORT REEL"}
                </button>

                {exportDone && (
                  <div style={{ display:"flex", gap:8, marginTop:10 }}>
                    {[{label:"Instagram",color:"#e1306c",icon:"📸"},{label:"TikTok",color:"#69c9d0",icon:"🎵"},{label:"YouTube",color:"#ff0000",icon:"▶️"}].map(s => (
                      <button key={s.label} style={{ flex:1, padding:"8px 4px", borderRadius:8, fontSize:11, fontWeight:600, cursor:"pointer", border:`1px solid ${s.color}44`, background:`${s.color}11`, color:s.color, transition:"all .15s" }}
                        onMouseEnter={e => e.currentTarget.style.background=`${s.color}22`}
                        onMouseLeave={e => e.currentTarget.style.background=`${s.color}11`}
                      >{s.icon} {s.label}</button>
                    ))}
                  </div>
                )}
              </div>

            </div>{/* end left */}

            {/* ══════════ RIGHT PANEL ══════════ */}
            <div style={{ flex:1, minWidth:0, position:"sticky", top:20 }}>

              {/* Layers */}
              <div style={{ ...card, marginBottom:14 }}>
                <div style={{ fontSize:11, fontWeight:700, letterSpacing:"0.15em", color:"rgba(255,255,255,0.45)", textTransform:"uppercase", marginBottom:14 }}>Layers</div>
                {layers.length===0
                  ? <div style={{ fontSize:13, color:"rgba(255,255,255,0.25)", textAlign:"center", padding:"16px 0" }}>Add elements to see layers</div>
                  : <div style={{ display:"flex", flexDirection:"column", gap:4 }}>
                      {[...layers].reverse().map(layer => (
                        <div key={layer.id} style={{ display:"flex", alignItems:"center", gap:8, padding:"6px 10px", borderRadius:7, background:"rgba(255,255,255,0.04)", fontSize:12, color:"rgba(255,255,255,0.7)" }}>
                          <span>{layer.type==="video"?"🎬":layer.type==="image"?"🖼️":layer.type==="emoji"?"😀":layer.type==="shape"?"⬜":"✦"}</span>
                          <span style={{ flex:1, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{layer.label}</span>
                          <span style={{ fontSize:10, color:"#22c55e" }}>●</span>
                        </div>
                      ))}
                    </div>
                }
              </div>

              {/* Live Preview */}
              <div style={card}>
                <div style={{ fontSize:11, fontWeight:700, letterSpacing:"0.15em", color:"rgba(255,255,255,0.45)", textTransform:"uppercase", marginBottom:10 }}>Live Preview</div>
                <p style={{ fontSize:10, color:"rgba(255,255,255,0.25)", marginBottom:14, textAlign:"center" }}>Drag media to pan · scroll/pinch to zoom · drag elements to move</p>

                <div style={{ display:"flex", justifyContent:"center", marginBottom:16 }}>
                  <div style={{ width:200, height:360, borderRadius:28, background:"#111", border:"3px solid #333", position:"relative", overflow:"hidden", boxShadow:"0 20px 60px rgba(0,0,0,0.7)" }}>
                    {/* Notch */}
                    <div style={{ position:"absolute", top:0, left:"50%", transform:"translateX(-50%)", width:60, height:16, background:"#111", borderRadius:"0 0 12px 12px", zIndex:10 }} />

                    {/* Content */}
                    <div style={{ width:"100%", height:"100%", background: previewBg ? `url(${previewBg}) center/cover` : "linear-gradient(180deg,#1a1a2e,#0d0d18)", display:"flex", flexDirection:"column", justifyContent:"flex-end", padding:12 }}>
                      {activeOverlays.vignette && <div style={{ position:"absolute", inset:0, background:"radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.7) 100%)", pointerEvents:"none" }} />}
                      {activeOverlays.bars && <>
                        <div style={{ position:"absolute", top:0, left:0, right:0, height:28, background:"#000", pointerEvents:"none" }} />
                        <div style={{ position:"absolute", bottom:0, left:0, right:0, height:28, background:"#000", pointerEvents:"none" }} />
                      </>}

                      {caption && (
                        <div style={{ marginBottom:8, fontSize:Math.min(fontSize*0.28,14), fontWeight: activeTextStyle?.fontWeight||700, color: ACCENT_MAP[accentColor]||"#ff3c7e", textShadow: textStyle==="shadow" ? "2px 2px 0 #000" : "none" }}>
                          {caption}
                        </div>
                      )}
                      {handle && <div style={{ fontSize:9, color:"rgba(255,255,255,0.6)", marginBottom:4 }}>{handle}</div>}
                      {!previewBg && !caption && (
                        <div style={{ position:"absolute", inset:0, display:"flex", alignItems:"center", justifyContent:"center" }}>
                          <span style={{ fontSize:32, opacity:0.2 }}>▶</span>
                        </div>
                      )}
                    </div>
                  </div>
                </div>

                <div style={{ display:"flex", gap:8, justifyContent:"center" }}>
                  {["▶ Play","■ Stop"].map(b => (
                    <button key={b} style={{ padding:"7px 20px", borderRadius:7, fontSize:12, fontWeight:600, background:"rgba(255,255,255,0.07)", border:"1px solid rgba(255,255,255,0.12)", color:"rgba(255,255,255,0.8)", cursor:"pointer" }}>{b}</button>
                  ))}
                </div>
              </div>

            </div>{/* end right */}
          </div>
        </div>
      );
    }

    ReactDOM.createRoot(document.getElementById("root")).render(<App />);
  </script>
</body>
</html>

# 🎬 Reel Maker

A fully self-contained social media reel builder — no build step required.

## Deploy in 2 minutes

### GitHub Pages
1. Push this folder to a GitHub repo
2. Go to **Settings → Pages → Source → main branch / root**
3. Your app is live at `https://<you>.github.io/<repo>`

### Vercel (recommended)
1. Push to GitHub
2. Go to [vercel.com/new](https://vercel.com/new) → import the repo
3. Framework preset: **Other** — click Deploy
4. Done ✅

## AI Captions
The Generate Captions button calls the Anthropic API directly from the browser.
When you click it, a prompt will appear asking for your Anthropic API key (`sk-ant-...`).
Your key is never stored — it lives only in memory for that session.

Get a key at [console.anthropic.com](https://console.anthropic.com).

## Features
- Upload videos & images into a sequenced timeline
- Picture-in-picture overlays
- 6 text styles, accent colors, font size control
- Vignette / Cinematic Bars / Film Grain / Edge Blur overlays
- Shapes, emojis, voiceover
- AI-powered caption generation (Claude)
- Export settings: format, quality, aspect ratio, FPS

